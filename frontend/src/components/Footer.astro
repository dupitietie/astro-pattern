---
// 自动获取当前年份
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <p>&copy; {currentYear} Tiny Crochet. All rights reserved.</p>
  <p class="sub-text">Digital PDF Amigurumi Patterns</p>
  
  <div class="legal-links">
    <a href="/privacy">Privacy Policy</a>
    <span class="divider">|</span>
    <a href="/terms">Terms of Service</a>
  </div>
</footer>

<style>
  .site-footer {
    padding: 4rem 2rem 2rem;
    text-align: center;
    border-top: 1px solid var(--color-placeholder, #eaeaea);
    margin-top: auto; /* 保证 footer 永远在页面最底部 */
  }

  p {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 500;
  }

  .sub-text {
    margin-top: 0.5rem;
    font-size: 0.75rem;
    opacity: 0.5;
  }

  /* 法律链接的专属样式 */
  .legal-links {
    margin-top: 1.5rem;
    font-size: 0.8rem;
  }

  .legal-links a {
    color: #888;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .legal-links a:hover {
    color: #111;
    text-decoration: underline;
  }

  .divider {
    margin: 0 0.8rem;
    color: #ccc;
    font-size: 0.7rem;
  }
</style>