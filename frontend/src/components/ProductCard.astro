---
type Props = {
  product: {
    id: string;
    name: string;
    description: string;
    price: number; // 👈 已经为你同步修改为 number
    imageUrl: string;
    stripeLink: string;
  };
};

const { product } = Astro.props;
const creatorName = "Tiny Crochet"; 

/**
 * 对 Cloudflare Image Resizing URL 注入 format=auto 和 quality=80
 * format=auto: 根据浏览器自动返回 WebP/AVIF，体积减少 25-35%
 * quality=80: 适度压缩，肉眼无差异，体积再减 10-15%
 */
function optimizeImageUrl(url: string): string {
  const cdnPrefix = "/cdn-cgi/image/";
  const idx = url.indexOf(cdnPrefix);
  if (idx === -1) return url;

  const paramsStart = idx + cdnPrefix.length;
  const paramsEnd = url.indexOf("/", paramsStart);
  if (paramsEnd === -1) return url;

  const params = url.substring(paramsStart, paramsEnd);
  const optimizedParams = params + ",format=auto,quality=80";
  return url.substring(0, paramsStart) + optimizedParams + url.substring(paramsEnd);
}

const optimizedImageUrl = optimizeImageUrl(product.imageUrl);
---

<a 
  class="product-card"
  data-product-title={product.name}
  data-creator-name={creatorName}
  data-price={`$${product.price}`}
  href={product.stripeLink} 
  target="_blank"
>
  <article>
    <div class="image-container">
      <img 
        src={optimizedImageUrl} 
        alt={product.name} 
        width="800" 
        height="800" 
        loading="lazy"
        decoding="async"
        class="custom-image"
      />
    </div>
    
    <div class="mobile-info">
      <h3 class="mobile-title">{product.name}</h3>
      <span class="mobile-price">${product.price}</span>
    </div>
    
    <span class="sr-only">
      <h3>{product.name}</h3>
      <p>{creatorName}</p>
    </span>
  </article>
</a>

<style>
  .product-card {
    display: flex;
    gap: 0.5rem;
    flex-direction: column;
    align-content: start;
    width: 100%;
    max-width: 300px; 
    margin: 0 auto; 
    text-decoration: none;
    color: inherit;
  }

  .image-container {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
  }

  .custom-image {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1; 
    object-fit: cover;
    background: var(--color-placeholder, #f0f0f0);
    display: block;
    border-radius: 12px; 
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
  }

  .mobile-info {
    margin-top: 0.75rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    font-size: 0.9rem;
    line-height: 1.2;
    padding: 0 0.25rem; 
  }

  .mobile-title {
    font-weight: 600;
    margin: 0;
    max-width: 70%;
  }

  .mobile-price {
    font-weight: normal;
    opacity: 0.8;
  }

  @media (hover: hover) {
    .mobile-info {
      display: none;
    }
  }
</style>