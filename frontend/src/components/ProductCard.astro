---
type Props = {
  product: {
    id: string;
    name: string;
    description: string;
    price: number; // 👈 已经为你同步修改为 number
    imageUrl: string;
    stripeLink: string;
  };
};

const { product } = Astro.props;
const creatorName = "Tiny Crochet"; 

/**
 * 生成 Cloudflare Image Resizing 优化 URL
 * 替换尺寸参数并注入 format=auto + quality=80
 */
function generateImageVariant(url: string, width: number, height: number): string {
  const cdnPrefix = "/cdn-cgi/image/";
  const idx = url.indexOf(cdnPrefix);
  if (idx === -1) return url;

  const paramsStart = idx + cdnPrefix.length;
  const paramsEnd = url.indexOf("/", paramsStart);
  if (paramsEnd === -1) return url;

  const newParams = `width=${width},height=${height},fit=crop,format=auto,quality=80`;
  return url.substring(0, paramsStart) + newParams + url.substring(paramsEnd);
}

// 三种尺寸对应安全规则白名单
const src400 = generateImageVariant(product.imageUrl, 400, 400);
const src600 = generateImageVariant(product.imageUrl, 600, 600);
const src1080 = generateImageVariant(product.imageUrl, 1080, 1080);

const srcset = `${src400} 400w, ${src600} 600w, ${src1080} 1080w`;
// sizes 匹配 ProductGrid 的断点: 2列(≤30em) / 4列(≤50em) / 6列(>50em)
const sizes = "(max-width: 30em) 50vw, (max-width: 50em) 25vw, 16.67vw";
---

<a 
  class="product-card"
  data-product-title={product.name}
  data-creator-name={creatorName}
  data-price={`$${product.price}`}
  href={product.stripeLink} 
  target="_blank"
>
  <article>
    <div class="image-container">
      <img 
        src={src600} 
        srcset={srcset}
        sizes={sizes}
        alt={product.name} 
        width="600" 
        height="600" 
        loading="lazy"
        decoding="async"
        class="custom-image"
      />
    </div>
    
    <div class="mobile-info">
      <h3 class="mobile-title">{product.name}</h3>
      <span class="mobile-price">${product.price}</span>
    </div>
    
    <span class="sr-only">
      <h3>{product.name}</h3>
      <p>{creatorName}</p>
    </span>
  </article>
</a>

<style is:global>
  .product-card {
    display: flex;
    gap: 0.5rem;
    flex-direction: column;
    align-content: start;
    width: 100%;
    max-width: 300px; 
    margin: 0 auto; 
    text-decoration: none;
    color: inherit;
  }

  .image-container {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
  }

  .custom-image {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1; 
    object-fit: cover;
    background: var(--color-placeholder, #f0f0f0);
    display: block;
    border-radius: 12px; 
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
  }

  .mobile-info {
    margin-top: 0.75rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    font-size: 0.9rem;
    line-height: 1.2;
    padding: 0 0.25rem; 
  }

  .mobile-title {
    font-weight: 600;
    margin: 0;
    max-width: 70%;
  }

  .mobile-price {
    font-weight: normal;
    opacity: 0.8;
  }

  @media (hover: hover) {
    .mobile-info {
      display: none;
    }
  }
</style>