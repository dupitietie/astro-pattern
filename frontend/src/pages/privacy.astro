---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Privacy Policy - Tiny Crochet">
  <div class="legal-container">
    <h1>Privacy Policy</h1>
    <p>Last updated: {new Date().toLocaleDateString()}</p>
    
    <h2>1. Information We Collect</h2>
    <p>We collect your email address solely for the purpose of delivering the digital PDF crochet patterns you purchase and providing customer support.</p>
    
    <h2>2. Payment Information</h2>
    <p>All payments are securely processed by Stripe. We do not store, process, or have access to your credit card details or financial information.</p>
    
    <h2>3. How We Use Your Information</h2>
    <p>Your email address is used exclusively to send your purchased digital downloads. We will never sell, rent, or share your personal information with third parties.</p>

    <h2>4. Contact Us</h2>
    <p>If you have any questions about this Privacy Policy, please contact us at <strong>contact@unihandcraft.com</strong>.</p>
  </div>
</BaseLayout>

<style>
  .legal-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 2rem;
    line-height: 1.6;
    font-family: inherit;
  }
  h1 { font-size: 2rem; margin-bottom: 0.5rem; }
  h2 { font-size: 1.25rem; margin-top: 2rem; margin-bottom: 1rem; }
  p { margin-bottom: 1rem; color: #555; font-size: 0.95rem; }
</style>